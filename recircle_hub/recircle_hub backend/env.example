# Rename this file to ".env" and fill in your values

# ── PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reworth
DB_USER=postgres
DB_PASSWORD=postgres

# ── Flask ───────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string

# ── Google Gemini (AI Waste Detector) ───────────────────────────
# Paste your Google AI Studio API key here, then restart the server.
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
